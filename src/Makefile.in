rpp$(EXEEXT): $(rpp_OBJECTS) $(rpp_DEPENDENCIES) $(EXTRA_rpp_DEPENDENCIES) 
	@rm -f rpp$(EXEEXT)
	$(AM_V_CCLD)$(rpp_LINK) $(rpp_OBJECTS) $(rpp_LDADD) $(LIBS)

